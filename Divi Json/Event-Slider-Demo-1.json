\n\\n\\u003ch3\\u003eASHA BHOSLE\\u003c\/h3\\u003e\\n\\n\\u003ch4\\u003e2011 \u2022 Australia\\u003c\/h4\\u003e\\n\\n\\u003cp\\u003eLive in Concert\\u003c\/p\\u003e\\n\\n\\u003c\/div\\u003e\\n\\n\\u003c\/div\\u003e\\n\\n\\u003c\/div\\u003e\\n\\n\\u003c\/div\\u003e\\n\\n\\u003c\/div\\u003e\\n\\n\\u003cdiv class=\\u0022drag-text\\u0022\\u003e\\nDrag to spin the archive \u2022 Hover a concert to bring it forward\\n\\u003c\/div\\u003e\\n\\n\\u003c\/section\\u003e\\n\\n\\u003cscript\\u003e\\n\\nnew Swiper(\\u0022.concertSwiper\\u0022,{\\n\\nslidesPerView:\\u0022auto\\u0022,\\n\\ncenteredSlides:true,\\n\\nspaceBetween:-60,\\n\\ngrabCursor:true,\\n\\nloop:true,\\n\\nspeed:900,\\n\\nfreeMode:true,\\n\\nmousewheel:true,\\n\\nfreeModeMomentum:true,\\n\\nfreeModeMomentumBounce:true,\\n\\n});\\n\\n\\u003c\/script\\u003e\\n\\n\\u003cscript src=\\u0022https:\/\/cdn.jsdelivr.net\/npm\/gsap@3\/dist\/gsap.min.js\\u0022\\u003e\\u003c\/script\\u003e\\n\\n\\u003cscript\\u003e\\n\\ndocument.querySelectorAll('.concert-card').forEach(card=\\u003e{\\n\\ncard.addEventListener('mouseenter',()=\\u003e{\\n\\ngsap.to(card,{\\n\\nscale:1.15,\\n\\nduration:.35,\\n\\nrotation:0,\\n\\nease:\\u0022power2.out\\u0022\\n\\n});\\n\\n});\\n\\ncard.addEventListener('mouseleave',()=\\u003e{\\n\\ngsap.to(card,{\\n\\nscale:1,\\n\\nrotation:Math.random()*6-3,\\n\\nduration:.35\\n\\n});\\n\\n});\\n\\n});\\n\\n\\u003c\/script\\u003e\"}}},\"builderVersion\":\"5.7.4\",\"css\":{\"desktop\":{\"value\":{\"freeForm\":\".concert-archive{\\n\\nbackground:#090909;\\n\\npadding:120px 0;\\n\\noverflow:hidden;\\n\\nposition:relative;\\n\\n}\\n\\n.archive-heading{\\n\\ntext-align:center;\\n\\nmax-width:900px;\\n\\nmargin:auto;\\n\\nmargin-bottom:80px;\\n\\n}\\n\\n.archive-heading h2{\\n\\nfont-size:62px;\\n\\nfont-weight:800;\\n\\ncolor:#ffd64d;\\n\\nline-height:1.1;\\n\\nletter-spacing:1px;\\n\\ntext-transform:uppercase;\\n\\n}\\n\\n.archive-heading p{\\n\\ncolor:#ddd;\\n\\nfont-size:20px;\\n\\nmargin-top:25px;\\n\\n}\\n\\n.gold-line{\\n\\nwidth:90px;\\n\\nheight:3px;\\n\\nbackground:#ffd64d;\\n\\nmargin:35px auto;\\n\\nbox-shadow:0 0 15px #ffd64d;\\n\\n}\\n\\n.concertSwiper{\\n\\noverflow:visible;\\n\\npadding-bottom:60px;\\n\\n}\\n\\n.swiper-slide{\\n\\nwidth:230px;\\n\\n}\\n\\n.concert-card{\\n\\nheight:360px;\\n\\nborder-radius:18px;\\n\\noverflow:hidden;\\n\\nposition:relative;\\n\\ntransform:rotate(-3deg);\\n\\ntransition:.4s;\\n\\nborder:1px solid rgba(255,214,77,.3);\\n\\n}\\n\\n.swiper-slide:nth-child(even) .concert-card{\\n\\ntransform:rotate(3deg);\\n\\n}\\n\\n.concert-card img{\\n\\nwidth:100%;\\n\\nheight:100%;\\n\\nobject-fit:cover;\\n\\n}\\n\\n.overlay{\\n\\nposition:absolute;\\n\\nleft:0;\\n\\nright:0;\\n\\nbottom:0;\\n\\npadding:25px;\\n\\nbackground:linear-gradient(transparent,rgba(0,0,0,.95));\\n\\n}\\n\\n.overlay span{\\n\\ndisplay:inline-block;\\n\\npadding:6px 12px;\\n\\nborder-radius:30px;\\n\\nfont-size:11px;\\n\\nbackground:rgba(255,255,255,.15);\\n\\nbackdrop-filter:blur(10px);\\n\\ncolor:white;\\n\\n}\\n\\n.overlay h3{\\n\\ncolor:white;\\n\\nmargin-top:15px;\\n\\nfont-size:26px;\\n\\n}\\n\\n.overlay h4{\\n\\ncolor:#ddd;\\n\\nfont-size:14px;\\n\\nmargin:6px 0;\\n\\n}\\n\\n.overlay p{\\n\\ncolor:#bdbdbd;\\n\\nfont-style:italic;\\n\\nfont-size:15px;\\n\\n}\\n\\n.concert-card:hover{\\n\\ntransform:scale(1.12);\\n\\nz-index:999;\\n\\nbox-shadow:0 30px 70px rgba(0,0,0,.5);\\n\\n}\\n\\n.drag-text{\\n\\ntext-align:center;\\n\\ncolor:#999;\\n\\nmargin-top:45px;\\n\\nfont-size:15px;\\n\\n}\\n\\n@media(max-width:980px){\\n\\n.archive-heading h2{\\n\\nfont-size:42px;\\n\\n}\\n\\n.archive-heading p{\\n\\nfont-size:17px;\\n\\n}\\n\\n.swiper-slide{\\n\\nwidth:190px;\\n\\n}\\n\\n.concert-card{\\n\\nheight:300px;\\n\\n}\\n\\n}\"}}}} \/-->\r\n<!-- \/wp:divi\/column -->\r\n<!-- \/wp:divi\/row -->\r\n<!-- \/wp:divi\/section --><!-- \/wp:divi\/placeholder -->","post_title":"Event-Slider-Demo-1","post_excerpt":"","post_status":"publish","comment_status":"closed","ping_status":"c