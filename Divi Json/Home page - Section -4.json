tive';d.addEventListener('click',function(){go(i)});dotsWrap.appendChild(d);dots.push(d);});}\\n  function step(){var gap=parseFloat(getComputedStyle(track).gap)||30;return cards[0].getBoundingClientRect().width+gap;}\\n  function current(){return Math.max(0,Math.min(cards.length-1,Math.round(track.scrollLeft\/step())))}\\n  function setDots(){var i=current();dots.forEach(function(d,idx){d.classList.toggle('active',idx===i);});}\\n  function go(i){track.scrollTo({left:i*step(),behavior:'smooth'});setTimeout(setDots,350)}\\n  if(next) next.addEventListener('click',function(e){e.preventDefault();var i=current()+1;if(i\\u003e=cards.length)i=0;go(i);});\\n  if(prev) prev.addEventListener('click',function(e){e.preventDefault();var i=current()-1;if(i\\u003c0)i=cards.length-1;go(i);});\\n  track.addEventListener('scroll',function(){window.requestAnimationFrame(setDots);});\\n});\\n\\u003c\/script\\u003e\\n\"}}},\"builderVersion\":\"5.0.0-public-alpha.23\",\"modulePreset\":[\"default\"]} \/-->\r\n\r\n<!-- wp:divi\/text {\"module\":{\"advanced\":{\"htmlAttributes\":{\"desktop\":{\"value\":{\"class\":\"pharmacy-medical-label\",\"id\":\"\"}}}},\"decoration\":{\"layout\":{\"desktop\":{\"value\":{\"display\":\"block\"}}}}},\"content\":{\"innerContent\":{\"desktop\":{\"value\":\"Services\"}}},\"builderVersion\":\"5.0.0-public-alpha.23\",\"modulePreset\":[\"default\"]} \/-->\r\n\r\n<!-- wp:divi\/text {\"module\":{\"advanced\":{\"htmlAttributes\":{\"desktop\":{\"value\":{\"class\":\"pharmacy-medical-title\",\"id\":\"\"}}}},\"decoration\":{\"layout\":{\"desktop\":{\"value\":{\"display\":\"block\"}}}}},\"content\":{\"innerContent\":{\"desktop\":{\"value\":\"Medical\\u003cbr\\u003eServices\"}}},\"builderVersion\":\"5.0.0-public-alpha.23\",\"modulePreset\":[\"default\"]} \/-->\r\n\r\n<!-- wp:divi\/text {\"module\":{\"advanced\":{\"htmlAttributes\":{\"desktop\":{\"value\":{\"class\":\"pharmacy-medical-desc\",\"id\":\"\"}}}},\"decoration\":{\"layout\":{\"desktop\":{\"value\":{\"display\"